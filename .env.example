# ===========================================
# Yahli AI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ===========================================

# --- Google Gemini API Key ---
# Note: This service costs money to run. A valid paid API key is required for better performance.
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Cloud Services ---
# Google Custom Search API key (for web research)
GOOGLE_API_KEY=your_google_search_api_key_here

# Google Custom Search Engine ID
SEARCH_ENGINE_ID=your_search_engine_id_here

# --- Telegram Bot ---
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Admin Configuration ---
# Your Telegram user ID (get it from @userinfobot on Telegram)
ADMIN_CHAT_ID=your_telegram_user_id_here

# --- LLM Provider Selection ---
# Choose which LLM backend to use: 'google' or 'ollama'
LLM_PROVIDER=google

# --- LLM Model Configuration ---
# Primary model for general tasks
GEMINI_MODEL_NAME=gemma-4-31b-it

# Model for complex reasoning tasks
GEMINI_MODEL_FOR_COMPLEX_NAME=gemma-4-31b-it

# Model for vision/OCR tasks (optional)
GEMINI_VISION_MODEL=gemma-4-31b-it

# Embedding model for vector memory (optional)
EMBEDDING_MODEL=models/gemini-embedding-001

# --- Memory Configuration (optional) ---
# Vector memory deduplication similarity threshold (0.0 - 1.0)
MEMORY_DEDUP_SIM=0.87

# Maximum items in embedding cache
MEMORY_MAX_CACHE_ITEMS=20000

# Maximum characters for memory summaries
MEMORY_MAX_SUMMARY_CHARS=1200

# Top-K results for reranking
MEMORY_RERANK_TOP_K=6

# --- Ollama (Local LLM - optional, set LLM_PROVIDER=ollama to use) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma-4-31b-it

# --- Debug Mode ---
# Set to 'true' to enable verbose API logging and to false to prod (there are features that true kills)
YAHLI_API_LOGGING=true

# --- Long-term Memory ---
# Set to 'true' to enable long-term memory retrieval (default: false)
ENABLE_LONG_TERM_MEMORY=false
